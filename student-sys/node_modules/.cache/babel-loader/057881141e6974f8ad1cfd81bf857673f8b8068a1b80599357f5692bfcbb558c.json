{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { login } from '@/api/student';\nexport default {\n  name: 'LoginPage',\n  data() {\n    return {\n      loading: false,\n      loginForm: {\n        username: '',\n        password: ''\n      },\n      rules: {\n        username: [{\n          required: true,\n          message: '请输入学号',\n          trigger: 'blur'\n        }],\n        password: [{\n          required: true,\n          message: '请输入密码',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  methods: {\n    handleLogin() {\n      login({\n        username: this.loginForm.username,\n        password: this.loginForm.password\n      }).then(res => {\n        if (res.data.code === 200) {\n          this.$message.success('登录成功');\n          this.$router.push('/students');\n        } else {\n          this.$message.error(res.data.message);\n          console.log(res);\n        }\n      }).catch(() => {\n        this.$message.error('登录请求失败');\n      });\n    }\n  }\n};","map":{"version":3,"names":["login","name","data","loading","loginForm","username","password","rules","required","message","trigger","methods","handleLogin","then","res","code","$message","success","$router","push","error","console","log","catch"],"sources":["src/views/LoginPage.vue"],"sourcesContent":["<template>\n    <div class=\"login-container\">\n        <el-card class=\"login-card\">\n            <h2 class=\"title\">教务管理系统</h2>\n            <el-form :model=\"loginForm\" :rules=\"rules\" ref=\"loginForm\" label-width=\"80px\">\n                <el-form-item label=\"学号\" prop=\"username\">\n                    <el-input v-model=\"loginForm.username\" placeholder=\"请输入学号\"></el-input>\n                </el-form-item>\n                <el-form-item label=\"密码\" prop=\"password\">\n                    <el-input v-model=\"loginForm.password\" placeholder=\"请输入密码\"\n                        @keyup.enter.native=\"handleLogin\"></el-input>\n                </el-form-item>\n                <el-form-item>\n                    <el-button type=\"primary\" style=\"width: 100%\" :loading=\"loading\" @click=\"handleLogin\">\n                        登 录\n                    </el-button>\n                </el-form-item>\n            </el-form>\n        </el-card>\n    </div>\n</template>\n\n<script>\nimport { login } from '@/api/student'\nexport default {\n    name:'LoginPage',\n    data() {\n        return {\n            loading: false,\n            loginForm: {\n                username: '',\n                password: ''\n            },\n            rules: {\n                username: [{ required: true, message: '请输入学号', trigger: 'blur' }],\n                password: [{ required: true, message: '请输入密码', trigger: 'blur' }]\n            }\n        }\n    },\n    methods: {\n        handleLogin() {\n           login({\n                username: this.loginForm.username,\n                password: this.loginForm.password\n           }).then(res => {\n                if (res.data.code === 200) {\n                    this.$message.success('登录成功')\n                    this.$router.push('/students')\n                } else {\n                    this.$message.error(res.data.message)\n                    console.log(res)\n                }\n            }).catch(() => {\n                this.$message.error('登录请求失败')\n            })\n           \n        }\n    }\n}\n</script>\n\n<style scoped>\n.login-container {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    height: 100vh;\n    background-color: #f0f2f5;\n}\n\n.login-card {\n    width: 400px;\n}\n\n.title {\n    text-align: center;\n    margin-bottom: 30px;\n    color: #409EFF;\n}\n</style>"],"mappings":";AAuBA,SAAAA,KAAA;AACA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,SAAA;QACAC,QAAA;QACAC,QAAA;MACA;MACAC,KAAA;QACAF,QAAA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAJ,QAAA;UAAAE,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAC,OAAA;IACAC,YAAA;MACAZ,KAAA;Q