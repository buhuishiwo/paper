{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nexport default {\n  data() {\n    return {\n      myCourses: [{\n        name: '高等数学',\n        time: '周一 08:00-10:00',\n        location: 'A-101',\n        credits: 4\n      }, {\n        name: '计算机网络',\n        time: '周三 14:00-16:00',\n        location: 'B-205',\n        credits: 3\n      }]\n    };\n  },\n  computed: {\n    totalCredits() {\n      return this.myCourses.reduce((sum, item) => sum + item.credits, 0);\n    }\n  },\n  methods: {\n    dropCourse(course) {\n      this.$confirm(`确定要退掉《${course.name}》吗？`, '退课警告', {\n        type: 'warning'\n      }).then(() => {\n        const index = this.myCourses.indexOf(course);\n        this.myCourses.splice(index, 1);\n        this.$message.success('退课成功');\n      }).catch(() => {});\n    },\n    dropAll() {\n      if (this.myCourses.length === 0) return;\n      this.$confirm('确定清空所有已选课程吗？此操作不可恢复', '高危操作', {\n        type: 'error'\n      }).then(() => {\n        this.myCourses = [];\n        this.$message.success('已清空所有课程');\n      }).catch(() => {});\n    }\n  }\n};","map":{"version":3,"names":["data","myCourses","name","time","location","credits","computed","totalCredits","reduce","sum","item","methods","dropCourse","course","$confirm","type","then","index","indexOf","splice","$message","success","catch","dropAll","length"],"sources":["src/views/MyCourses.vue"],"sourcesContent":["<template>\n  <div class=\"page-container\">\n    <el-card>\n      <div slot=\"header\">\n        <span>我的课表</span>\n        <el-button type=\"danger\" size=\"small\" style=\"float: right\" @click=\"dropAll\">一键退课</el-button>\n      </div>\n\n      <el-empty v-if=\"myCourses.length === 0\" description=\"暂未选择任何课程\"></el-empty>\n\n      <el-table v-else :data=\"myCourses\" style=\"width: 100%\">\n        <el-table-column prop=\"name\" label=\"课程名称\"></el-table-column>\n        <el-table-column prop=\"time\" label=\"上课时间\"></el-table-column>\n        <el-table-column prop=\"location\" label=\"地点\"></el-table-column>\n        <el-table-column prop=\"credits\" label=\"学分\"></el-table-column>\n        <el-table-column label=\"状态\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"scope.status === '正常' ? 'success' : 'warning'\">{{ scope.row.status || '正常' }}</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"100\">\n          <template slot-scope=\"scope\">\n            <el-button size=\"mini\" type=\"danger\" plain @click=\"dropCourse(scope.row)\">退课</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n      \n      <div style=\"margin-top: 20px; text-align: right; font-weight: bold;\">\n        总学分：{{ totalCredits }}\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      myCourses: [\n        { name: '高等数学', time: '周一 08:00-10:00', location: 'A-101', credits: 4 },\n        { name: '计算机网络', time: '周三 14:00-16:00', location: 'B-205', credits: 3 },\n      ]\n    };\n  },\n  computed: {\n    totalCredits() {\n      return this.myCourses.reduce((sum, item) => sum + item.credits, 0);\n    }\n  },\n  methods: {\n    dropCourse(course) {\n      this.$confirm(`确定要退掉《${course.name}》吗？`, '退课警告', {\n        type: 'warning'\n      }).then(() => {\n        const index = this.myCourses.indexOf(course);\n        this.myCourses.splice(index, 1);\n        this.$message.success('退课成功');\n      }).catch(() => {});\n    },\n    dropAll() {\n      if(this.myCourses.length === 0) return;\n      this.$confirm('确定清空所有已选课程吗？此操作不可恢复', '高危操作', {\n        type: 'error'\n      }).then(() => {\n        this.myCourses = [];\n        this.$message.success('已清空所有课程');\n      }).catch(() => {});\n    }\n  }\n};\n</script>"],"mappings":";;AAmCA;EACAA,KAAA;IACA;MACAC,SAAA,GACA;QAAAC,IAAA;QAAAC,IAAA;QAAAC,QAAA;QAAAC,OAAA;MAAA,GACA;QAAAH,IAAA;QAAAC,IA