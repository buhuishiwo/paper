{"ast":null,"code":"export default {\n  data() {\n    return {\n      courseList: []\n    };\n  },\n  methods: {\n    selectCourse(course) {\n      this.$confirm(`确认选择课程《${course.name}》吗？`, '选课确认', {\n        confirmButtonText: '确认选课',\n        cancelButtonText: '再想想',\n        type: 'info'\n      }).then(() => {\n        // 模拟后端更新\n        course.selected++;\n        this.$message.success('选课成功！');\n      }).catch(() => {});\n    }\n  }\n};","map":{"version":3,"names":["data","courseList","methods","selectCourse","course","$confirm","name","confirmButtonText","cancelButtonText","type","then","selected","$message","success","catch"],"sources":["src/views/CourseSelect.vue"],"sourcesContent":["<template>\n  <div class=\"page-container\">\n    <el-card>\n      <div slot=\"header\">\n        <span>可选课程列表</span>\n        <el-tag type=\"success\" style=\"float: right\">剩余学分：12</el-tag>\n      </div>\n\n      <el-table :data=\"courseList\" style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"课程代码\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"courseName\" label=\"课程名称\"></el-table-column>\n        <el-table-column prop=\"teacher\" label=\"授课教师\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"point\" label=\"学分\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"capacity\" label=\"容量/已选\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ scope.row.maxCapacity }} / {{ scope.row.selectedCount }}\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"120\">\n          <template slot-scope=\"scope\">\n            <el-button \n              type=\"primary\" \n              size=\"small\" \n              :disabled=\"scope.row.selectedCount >= scope.row.maxCapacity\"\n              @click=\"selectCourse(scope.row)\">\n              {{ scope.row.maxCapacity >= scope.row.selectedCount ? '已满' : '选课' }}\n            </el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      courseList: [\n\n      ]\n    };\n  },\n  methods: {\n    selectCourse(course) {\n      this.$confirm(`确认选择课程《${course.name}》吗？`, '选课确认', {\n        confirmButtonText: '确认选课',\n        cancelButtonText: '再想想',\n        type: 'info'\n      }).then(() => {\n        // 模拟后端更新\n        course.selected++;\n        this.$message.success('选课成功！');\n      }).catch(() => {});\n    }\n  }\n};\n</script>"],"mappings":"AAmCA;EACAA,KAAA;IACA;MACAC,UAAA;IAGA;EACA;EACAC,OAAA;IACAC,aAAAC,MAAA;MACA,KAAAC,QAAA,WAAAD,MAAA,CAAAE,IAAA;QACAC,iBAAA;QACAC,gBAAA;QACAC,IAAA;MACA,GAAAC,IAAA;QACA;QACAN,MAAA,CAAAO,QAAA;QACA,KAAAC,QAAA,CAAAC,OAAA;MACA,GAAAC,KAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}