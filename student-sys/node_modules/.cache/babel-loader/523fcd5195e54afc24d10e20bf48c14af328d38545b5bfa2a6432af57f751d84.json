{"ast":null,"code":"import \"core-js/modules/es.json.parse.js\";\nimport Cookies from \"js-cookie\";\nimport { getCourseList, selectCourseApi } from \"@/api/course\";\nexport default {\n  data() {\n    return {\n      courseList: []\n    };\n  },\n  created() {\n    this.loadCourses();\n  },\n  methods: {\n    loadCourses() {\n      getCourseList.then(res => {\n        if (res.data.code === 200) {\n          this.courseList = res.data.data;\n        }\n      });\n    },\n    selectCourse(row) {\n      const studentInfo = JSON.parse(Cookies.get('studentInfo'));\n      const studentId = studentInfo.id;\n      selectCourseApi({\n        studentId: studentId,\n        courseId: row.id\n      }).then(res => {\n        if (res.data.code === 200) {\n          this.$message.success(\"选课成功\");\n          this.loadCourses(); // 刷新列表\n        } else {\n          this.$message.error(res.data.message);\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["Cookies","getCourseList","selectCourseApi","data","courseList","created","loadCourses","methods","then","res","code","selectCourse","row","studentInfo","JSON","parse","get","studentId","id","courseId","$message","success","error","message"],"sources":["src/views/CourseSelect.vue"],"sourcesContent":["<template>\n  <div class=\"page-container\">\n    <el-card>\n      <div slot=\"header\">\n        <span>可选课程列表</span>\n        <el-tag type=\"success\" style=\"float: right\">剩余学分：12</el-tag>\n      </div>\n\n      <el-table :data=\"courseList\" style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"课程代码\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"courseName\" label=\"课程名称\"></el-table-column>\n        <el-table-column prop=\"teacher\" label=\"授课教师\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"point\" label=\"学分\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"capacity\" label=\"容量/已选\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ scope.row.maxCapacity }} / {{ scope.row.selectedCount }}\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"120\">\n          <template slot-scope=\"scope\">\n            <el-button \n              type=\"primary\" \n              size=\"small\" \n              :disabled=\"scope.row.selectedCount >= scope.row.maxCapacity\"\n              @click=\"selectCourse(scope.row)\">\n              {{ scope.row.selectedCount >= scope.row.maxCapacity ? '已满' : '选课' }}\n            </el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport Cookies from \"js-cookie\"\nimport {getCourseList,selectCourseApi} from \"@/api/course\"\n\nexport default {\n  data() {\n    return {\n      courseList: []\n    }\n  },\n\n  created() {\n    this.loadCourses()\n  },\n\n  methods: {\n    loadCourses() {\n      getCourseList.then(res => {\n        if(res.data.code === 200) {\n          this.courseList = res.data.data\n        }\n      })\n    },\n\n    selectCourse(row) {\n      \n      const studentInfo = JSON.parse(Cookies.get('studentInfo'))\n      const studentId = studentInfo.id\n\n      selectCourseApi({\n        studentId: studentId,\n        courseId: row.id\n      }).then(res => {\n         if (res.data.code === 200) {\n          this.$message.success(\"选课成功\")\n          this.loadCourses()  // 刷新列表\n        } else {\n          this.$message.error(res.data.message)\n        }\n      })\n    }\n  }\n};\n</script>"],"mappings":";AAmCA,OAAAA,OAAA;AACA,SAAAC,aAAA,EAAAC,eAAA;AAEA;EACAC,KAAA;IACA;MACAC,UAAA;IACA;EACA;EAEAC,QAAA;IACA,KAAAC,WAAA;EACA;EAEAC,OAAA;IACAD,YAAA;MACAL,aAAA,CAAAO,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAN,IAAA,CAAAO,IAAA;UACA,KAAAN,UAAA,GAAAK,GAAA,CAAAN,IAAA,CAAAA,IAAA;QACA;MACA;IACA;IAEAQ,aAAAC,GAAA;MAEA,MAAAC,WAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAf,OAAA,CAAAgB,GAAA;MACA,MAAAC,SAAA,GAAAJ,WAAA,CAAAK,EAAA;MAEAhB,eAAA;QACAe,SAAA,EAAAA,SAAA;QACAE,QAAA,EAAAP,GAAA,CAAAM;MACA,GAAAV,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAN,IAAA,CAAAO,IAAA;UACA,KAAAU,QAAA,CAAAC,OAAA;UACA,KAAAf,WAAA;QACA;UACA,KAAAc,QAAA,CAAAE,KAAA,CAAAb,GAAA,CAAAN,IAAA,CAAAoB,OAAA;QACA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}