{"ast":null,"code":"export default {\n  name: 'App'\n  // 注意：这里不需要注册 HelloWorld，也不需要注册任何页面组件\n  // 因为页面组件是通过 router-view 动态加载的\n};","map":{"version":3,"names":["name"],"sources":["src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <!-- 路由视图：根据 URL 显示对应的组件 (Login, StudentInfo 等) -->\n    <router-view />\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'App',\n  // 注意：这里不需要注册 HelloWorld，也不需要注册任何页面组件\n  // 因为页面组件是通过 router-view 动态加载的\n};\n</script>\n\n<style>\n/* 全局重置样式 */\nbody {\n  margin: 0;\n  padding: 0;\n  font-family: \"Helvetica Neue\", Helvetica, \"PingFang SC\", \"Hiragino Sans GB\", \"Microsoft YaHei\", \"微软雅黑\", Arial, sans-serif;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n#app {\n  width: 100%;\n  height: 100%;\n}\n\n/* 移除默认的 img 样式，如果你不再需要 logo */\nimg {\n  display: none; \n}\n</style>"],"mappings":"AAQA;EACAA,IAAA;EACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}